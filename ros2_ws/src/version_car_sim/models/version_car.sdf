      <pose>-0.32 -0.31 0.11 0 0 1.57079632679</pose>
      <inertial>
        <mass>0.65</mass>
        <inertia>
          <ixx>0.0030</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0045</iyy>
          <iyz>0.0</iyz>
          <izz>0.0030</izz>
        </inertia>
