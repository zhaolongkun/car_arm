    <link name="mid360_link">
      <pose>0.08 0 0.43 0 0 0</pose>
      <inertial>
        <mass>0.28</mass>
        <inertia>
          <ixx>0.00045</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00045</iyy>
          <iyz>0.0</iyz>
          <izz>0.0006</izz>
        </inertia>
      </inertial>
      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
      <visual name="lidar_window_visual">
        <pose>0 0 0.02 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.049</radius>
            <length>0.012</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.10 0.45 0.72 0.85</ambient>
          <diffuse>0.12 0.55 0.88 0.85</diffuse>
        </material>
      </visual>

      <sensor name="mid360_scan" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1.0</resolution>
              <min_angle>0.0</min_angle>
              <max_angle>0.0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.10</min>
            <max>35.0</max>
            <resolution>0.02</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.015</stddev>
          </noise>
        </ray>
        <plugin name="mid360_laserscan" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>base_link</frame_name>
        </plugin>
        <plugin name="mid360_points" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=mid360_points</remapping>
          </ros>
          <output_type>sensor_msgs/PointCloud2</output_type>
          <frame_name>base_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="front_steering_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_steering_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="front_left_wheel_joint" type="universal">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.4</damping>
        </dynamics>
      </axis>
      <axis2>
        <xyz>1 0 0</xyz>
        <dynamics>
          <friction>0.20</friction>
        </dynamics>
      </axis2>
    </joint>

    <joint name="front_right_wheel_joint" type="universal">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.4</damping>
        </dynamics>
      </axis>
      <axis2>
        <xyz>1 0 0</xyz>
        <dynamics>
          <friction>0.20</friction>
        </dynamics>
      </axis2>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.15</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.15</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="mid360_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>mid360_link</child>
    </joint>

    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <publish_rate>30.0</publish_rate>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </model>
</sdf>
