      <visual name="tire_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.11</radius>
            <length>0.065</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
