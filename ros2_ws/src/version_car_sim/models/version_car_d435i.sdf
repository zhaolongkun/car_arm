        </material>
      </visual>
      <visual name="d435i_mount_visual">
        <pose>-0.025 0 -0.045 0 0 0</pose>
        <geometry>
          <box>
            <size>0.08 0.16 0.035</size>
          </box>
        </geometry>
        <material>
          <ambient>0.18 0.18 0.17 1</ambient>
          <diffuse>0.24 0.24 0.22 1</diffuse>
        </material>
      </visual>

      <sensor name="d435i_depth_camera" type="depth">
        <pose>0.045 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.211</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <depth_camera>
          </depth_camera>
          <clip>
            <near>0.10</near>
            <far>8.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.003</stddev>
          </noise>
        </camera>
        <plugin name="d435i_camera_controller" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>d435i</namespace>
            <remapping>camera/image_raw:=color/image_raw</remapping>
            <remapping>camera/camera_info:=color/camera_info</remapping>
            <remapping>camera/depth/image_raw:=depth/image_raw</remapping>
            <remapping>camera/depth/camera_info:=depth/camera_info</remapping>
            <remapping>camera/points:=depth/points</remapping>
          </ros>
          <camera_name>camera</camera_name>
          <frame_name>d435i_depth_optical_frame</frame_name>
          <min_depth>0.20</min_depth>
          <max_depth>6.0</max_depth>
        </plugin>
      </sensor>
    </link>

    <joint name="front_steering_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_steering_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.8</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="front_left_wheel_joint" type="universal">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.4</damping>
        </dynamics>
      </axis>
      <axis2>
        <xyz>1 0 0</xyz>
        <dynamics>
          <friction>0.20</friction>
        </dynamics>
      </axis2>
    </joint>

    <joint name="front_right_wheel_joint" type="universal">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.70</lower>
          <upper>0.70</upper>
        </limit>
        <dynamics>
          <damping>0.4</damping>
        </dynamics>
      </axis>
      <axis2>
        <xyz>1 0 0</xyz>
        <dynamics>
          <friction>0.20</friction>
        </dynamics>
      </axis2>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.15</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.15</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="mid360_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>mid360_link</child>
    </joint>

    <joint name="d435i_camera_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>d435i_link</child>
    </joint>

    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <publish_rate>30.0</publish_rate>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </model>
</sdf>
