  <link name="d435i_depth_optical_frame"/>
  <joint name="d435i_depth_optical_fixed" type="fixed">
    <parent link="d435i_link"/>
    <child link="d435i_depth_optical_frame"/>
    <origin xyz="0.045 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>
</robot>
