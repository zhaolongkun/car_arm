    <child link="rear_right_wheel"/>
    <origin xyz="-0.32 -0.31 0.11" rpy="0 0 1.57079632679"/>
  </joint>

  <link name="d435i_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.075 0.135 0.038"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <visual>
      <origin xyz="0.044 0.038 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.016" length="0.008"/>
      </geometry>
      <material name="camera_lens"/>
    </visual>
    <visual>
      <origin xyz="0.044 -0.038 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.016" length="0.008"/>
      </geometry>
      <material name="camera_lens"/>
