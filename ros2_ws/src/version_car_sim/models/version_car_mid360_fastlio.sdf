<?xml version="1.0"?>
<sdf version="1.6">
  <model name="version_car">
    <pose>0 0 0 0 0 0</pose>

    <!-- ==================== base_link (MickX4-V3 四轮差速车体) ==================== -->
    <link name="base_link">
      <pose>0 0 0.16 0 0 0</pose>
      <inertial>
        <mass>12.0</mass>
        <inertia>
          <ixx>0.11</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.16</iyy>
          <iyz>0.0</iyz>
          <izz>0.22</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.58 0.34 0.16</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.58 0.34 0.16</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.11 0.13 1</ambient>
          <diffuse>0.07 0.26 0.30 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ==================== 四轮 ==================== -->
    <link name="front_left_wheel">
      <pose>0.20 0.20 0.10 0 0 1.57079632679</pose>
      <inertial>
        <mass>0.55</mass>
        <inertia>
          <ixx>0.0025</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0038</iyy>
          <iyz>0.0</iyz>
          <izz>0.0025</izz>
        </inertia>
      </inertial>
      <visual name="tire_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <visual name="hub_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.084</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.72 0.72 0.68 1</ambient>
          <diffuse>0.80 0.80 0.75 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.20</mu>
              <mu2>0.35</mu2>
              <slip1>0.0</slip1>
              <slip2>0.08</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+9</kp>
              <kd>1.0</kd>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
    </link>

    <link name="front_right_wheel">
      <pose>0.20 -0.20 0.10 0 0 1.57079632679</pose>
      <inertial>
        <mass>0.55</mass>
        <inertia>
          <ixx>0.0025</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0038</iyy>
          <iyz>0.0</iyz>
          <izz>0.0025</izz>
        </inertia>
      </inertial>
      <visual name="tire_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <visual name="hub_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.084</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.72 0.72 0.68 1</ambient>
          <diffuse>0.80 0.80 0.75 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.20</mu>
              <mu2>0.35</mu2>
              <slip1>0.0</slip1>
              <slip2>0.08</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+9</kp>
              <kd>1.0</kd>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
    </link>

    <link name="rear_left_wheel">
      <pose>-0.20 0.20 0.10 0 0 1.57079632679</pose>
      <inertial>
        <mass>0.65</mass>
        <inertia>
          <ixx>0.0030</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0045</iyy>
          <iyz>0.0</iyz>
          <izz>0.0030</izz>
        </inertia>
      </inertial>
      <visual name="tire_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <visual name="hub_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.084</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.68 0.68 0.62 1</ambient>
          <diffuse>0.78 0.78 0.70 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.20</mu>
              <mu2>0.35</mu2>
              <slip1>0.0</slip1>
              <slip2>0.08</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+9</kp>
              <kd>1.0</kd>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
    </link>

    <link name="rear_right_wheel">
      <pose>-0.20 -0.20 0.10 0 0 1.57079632679</pose>
      <inertial>
        <mass>0.65</mass>
        <inertia>
          <ixx>0.0030</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0045</iyy>
          <iyz>0.0</iyz>
          <izz>0.0030</izz>
        </inertia>
      </inertial>
      <visual name="tire_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
      <visual name="hub_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.050</radius>
            <length>0.084</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.68 0.68 0.62 1</ambient>
          <diffuse>0.78 0.78 0.70 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.20</mu>
              <mu2>0.35</mu2>
              <slip1>0.0</slip1>
              <slip2>0.08</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+9</kp>
              <kd>1.0</kd>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
    </link>

    <!-- ==================== MID360 3D 激光雷达 link ==================== -->
    <link name="mid360_link">
      <!-- MID360 安装在 MickX4-V3 车头顶部位置 -->
      <pose>0.24 0 0.275 0 0 0</pose>
      <inertial>
        <mass>0.28</mass>
        <inertia>
          <ixx>0.00045</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00045</iyy>
          <iyz>0.0</iyz>
          <izz>0.0006</izz>
        </inertia>
      </inertial>

      <!-- 雷达外观：圆柱体 -->
      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.07</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
      <visual name="lidar_window_visual">
        <pose>0 0 0.02 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.049</radius>
            <length>0.012</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.10 0.45 0.72 0.85</ambient>
          <diffuse>0.12 0.55 0.88 0.85</diffuse>
        </material>
      </visual>

      <!-- MID360 3D 激光雷达传感器（Ray 模式，同时输出 2D LaserScan 和 3D PointCloud2） -->
      <sensor name="mid360_livox3d" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <visualize>false</visualize>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>1.0</resolution>
              <min_angle>-0.43633231</min_angle>
              <max_angle>0.43633231</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.10</min>
            <max>18.0</max>
            <resolution>0.02</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.015</stddev>
          </noise>
        </ray>
        <!-- 3D PointCloud2 输出（用于 FAST-LIO） -->
        <plugin name="mid360_points" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=mid360_points</remapping>
          </ros>
          <output_type>sensor_msgs/PointCloud2</output_type>
          <frame_name>mid360_link</frame_name>
        </plugin>
        <!-- 2D LaserScan 输出（可选，保留给其他用途） -->
        <plugin name="mid360_laserscan" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>mid360_link</frame_name>
        </plugin>
      </sensor>

      <!-- IMU 传感器（与 MID360 在同一 link 上，外参为 Identity） -->
      <sensor name="mid360_imu" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>200</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0005</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0005</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0005</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
        <plugin name="mid360_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <remapping>~/out:=imu</remapping>
          </ros>
          <frame_name>mid360_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <!-- ==================== 关节：四轮差速，前轮不再转向 ==================== -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- MID360 固定在 base_link 上 -->
    <joint name="mid360_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>mid360_link</child>
    </joint>

    <!-- ==================== 运动插件 ==================== -->
    <!-- 四轮滑移/差速驱动：left=(vx-wz*0.40/2)/0.10, right=(vx+wz*0.40/2)/0.10 -->
    <plugin name="skid_steer_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>

      <update_rate>100.0</update_rate>
      <num_wheel_pairs>2</num_wheel_pairs>

      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>0.40</wheel_separation>
      <wheel_separation>0.40</wheel_separation>
      <wheel_diameter>0.20</wheel_diameter>
      <wheel_diameter>0.20</wheel_diameter>

      <max_wheel_torque>40.0</max_wheel_torque>
      <max_wheel_acceleration>40.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </model>
</sdf>
