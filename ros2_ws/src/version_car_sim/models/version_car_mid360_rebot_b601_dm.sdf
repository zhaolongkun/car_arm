    <!-- ==================== 关节：四轮差速，前轮不再转向 ==================== -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
        <dynamics>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>
    <!-- MID360 固定在 base_link 上 -->
    <joint name="mid360_fixed_joint" type="fixed">
      <parent>base_link</parent>
      <child>mid360_link</child>
    </joint>
    <!-- ==================== 运动插件 ==================== -->
    <!-- 四轮滑移/差速驱动：left=(vx-wz*0.40/2)/0.10, right=(vx+wz*0.40/2)/0.10 -->
    <plugin name="skid_steer_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.40</wheel_separation>
      <wheel_separation>0.40</wheel_separation>
      <wheel_diameter>0.20</wheel_diameter>
      <wheel_diameter>0.20</wheel_diameter>
      <max_wheel_torque>40.0</max_wheel_torque>
      <max_wheel_acceleration>40.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
    <plugin name="rebot_arm_joint_pose_trajectory" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <remapping>set_joint_trajectory:=/gazebo_arm/set_joint_trajectory</remapping>
      </ros>
      <update_rate>50.0</update_rate>
    </plugin>
  </model>
</sdf>
