      </inertial>
      <visual name="rebot_base_link_visual">
        <pose>0 0 0 0 -0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://rebotarm_bringup/description/meshes_b601_gripper/base_link.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.005 0.008 0.006 1</ambient>
          <diffuse>0.01 0.015 0.012 1</diffuse>
          <specular>0.08 0.10 0.08 1</specular>
        </material>
      </visual>
    </link>
    <joint name="base_to_rebot_base_joint" type="fixed">
      <parent>base_link</parent>
      <child>rebot_base_link</child>
    </joint>
    <joint name="joint1" type="revolute">
      <pose relative_to="rebot_base_link">-8.4e-05 0 0.08465 0 -0 0</pose>
      <parent>rebot_base_link</parent>
      <child>link1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-2.8</lower>
          <upper>2.8</upper>
          <effort>27</effort>
          <velocity>50</velocity>
        </limit>
        <dynamics>
          <damping>0.4</damping>
          <friction>0.02</friction>
